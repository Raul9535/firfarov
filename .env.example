# ─── Site ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://firfarov.com

# ─── Sanity ─────────────────────────────────────────────────────
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
# Only needed for draft previews / authenticated reads.
SANITY_API_READ_TOKEN=

# ─── Contact form ───────────────────────────────────────────────
# Resend — transactional email delivery for contact enquiries.
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@firfarov.com
CONTACT_FROM_EMAIL=no-reply@firfarov.com

# Supabase — persistence of contact submissions.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Analytics ──────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ─── Monitoring (Sentry) ────────────────────────────────────────
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
